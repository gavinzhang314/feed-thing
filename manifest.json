{

    "manifest_version": 2,
    "name": "Feed Thing",
    "version": "0.1",

    "browser_specific_settings": {
        "gecko": {
            "id": "@feed-thing",
            "data_collection_permissions": {
                "required": ["none"]
            },
            "strict_min_version": "58.0"
        }
    },

    "description": "A RSS feed aggregator.",

    "permissions": [
        "sessions",
        "activeTab",
        "tabs",
        "storage",
        "webRequest",
        "webRequestBlocking",
        "<all_urls>"
    ],

    "icons": {
        "128": "icons/icon.svg"
    },

    "sidebar_action": {
        "default_icon": {
            "128": "icons/icon.svg"
        },
        "default_title": "Feed Thing",
        "default_panel": "sidebar/sidebar.html",
        "open_at_install": true,
        "browser_style": false
    },

    "browser_action": {
        "default_icon": "icons/icon.svg",
        "default_popup": "browser_action/browser_action.html",
        "browser_style": false
    },

    "background": {
        "page": "background/background.html"
    }
}